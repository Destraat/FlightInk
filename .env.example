HOME_LAT=50.8514
HOME_LON=5.6910
RADIUS_NM=10
REFRESH_SECONDS=60
MAXIMUM_DISTANCE_KM=20
MINIMUM_ALTITUDE_FT=500
SELECTION_HOLD_SECONDS=90
REQUEST_TIMEOUT_SECONDS=15
STALE_AIRCRAFT_SECONDS=900
STALE_WEATHER_SECONDS=3600
PREDICTION_HORIZON_SECONDS=900

# Aircraft source: local, remote, or hybrid.
# local  = RTL-SDR USB receiver through dump1090/readsb only
# remote = Airplanes.live only
# hybrid = local receiver first, Airplanes.live as fallback
AIRCRAFT_SOURCE=hybrid
LOCAL_ADSB_URL=http://127.0.0.1:8080/data/aircraft.json
LOCAL_ADSB_TIMEOUT_SECONDS=3

# Route lookup. Exact local callsign routes are tried first, followed by OpenSky
# using the aircraft ICAO24/Mode-S hex address. Anonymous access works with
# reduced limits. Add OAuth client credentials from your OpenSky account for
# more reliable access.
OPENSKY_ROUTES_ENABLED=true
OPENSKY_API_BASE=https://opensky-network.org/api
OPENSKY_ROUTE_LOOKBACK_HOURS=36
OPENSKY_ROUTE_CACHE_SECONDS=1800
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

OUTPUT_PATH=output/flightink.png
DATABASE_PATH=data/flightink.db
CACHE_PATH=data/cache.json
DISPLAY_BACKEND=preview
WAVESHARE_MODULE=waveshare_epd.epd7in5_V2

# E-paper transition: direct, white, or erase.
# erase progressively dithers the previous image toward white before drawing the new frame.
# More steps look slower but cause more full e-paper refreshes.
DISPLAY_TRANSITION=erase
TRANSITION_STEPS=2
TRANSITION_DELAY_SECONDS=0.5

ADMIN_HOST=0.0.0.0
ADMIN_PORT=8090

# Planespotters photo integration.
# The public API normally forbids storing image binaries. Only set
# PLANESPOTTERS_IMAGE_CACHE_ENABLED=true when Planespotters has explicitly
# approved local download, processing and storage for your physical e-ink use.
PHOTO_PROVIDER=none
PLANESPOTTERS_USER_AGENT=FlightInk/1.0 (+https://github.com/Destraat/FlightInk)
PLANESPOTTERS_IMAGE_CACHE_ENABLED=false
PLANESPOTTERS_IMAGE_CACHE_DIR=data/aircraft_photos
PLANESPOTTERS_IMAGE_WIDTH=492
PLANESPOTTERS_IMAGE_HEIGHT=234
